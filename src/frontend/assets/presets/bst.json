{
  "meta": {
    "title": "BST Insertion & Search",
    "topic": "bst-web",
    "canvas": {"width": 1920, "height": 1080, "background": "#0f0f23"},
    "defaults": {
      "tree": {"nodeRadius": 32, "levelSpacing": 120, "siblingSpacing": 80, "nodeColor": "#2d4a7a", "nodeStroke": "#5b8fd9", "edgeColor": "#4a6a9a", "edgeWidth": 3, "strokeWidth": 3, "labelColor": "#ffffff", "labelFont": "22px monospace"},
      "text": {"font": "22px sans-serif", "color": "#d0d0ee"}
    },
    "palette": {"active": "#2ecc71", "visited": "#e74c3c", "found": "#f1c40f", "inserting": "#9b59b6", "path": "#e67e22"},
    "easing": "easeInOutCubic"
  },
  "scenes": [
    {
      "name": "intro",
      "transition": "none",
      "narration": "Welcome! Today we'll explore Binary Search Trees, one of the most important data structures in computer science. A BST keeps elements sorted so that searching, inserting, and deleting can all be done efficiently.",
      "manifest": {
        "meta": {"title": "BST Introduction", "canvas": {"width": 1920, "height": 1080, "background": "#0f0f23"}},
        "objects": [
          {"id": "title", "type": "text", "content": "", "position": {"x": 960, "y": 120}, "style": {"font": "bold 48px sans-serif", "align": "center", "color": "#ffffff"}},
          {"id": "subtitle", "type": "text", "content": "", "position": {"x": 960, "y": 200}, "style": {"font": "24px sans-serif", "align": "center", "color": "#aaaacc"}},
          {"id": "bst", "type": "tree", "variant": "binary", "root": "50", "position": {"x": 960, "y": 420}, "nodes": [
            {"id": "50", "label": "50"},
            {"id": "30", "label": "30", "parent": "50", "side": "left"},
            {"id": "70", "label": "70", "parent": "50", "side": "right"},
            {"id": "20", "label": "20", "parent": "30", "side": "left"},
            {"id": "40", "label": "40", "parent": "30", "side": "right"},
            {"id": "60", "label": "60", "parent": "70", "side": "left"},
            {"id": "80", "label": "80", "parent": "70", "side": "right"}
          ]},
          {"id": "rule", "type": "text", "content": "", "position": {"x": 960, "y": 850}, "style": {"font": "20px sans-serif", "align": "center", "color": "#88aacc"}}
        ],
        "timeline": [
          {"action": "set-text", "target": "title", "value": "Binary Search Tree"},
          {"action": "fade-in", "target": "title", "duration": "0.8s", "easing": "easeOutCubic"},
          {"action": "pause", "duration": "1s"},
          {"action": "set-text", "target": "subtitle", "value": "A sorted tree for fast search, insert & delete"},
          {"action": "fade-in", "target": "subtitle", "duration": "0.6s"},
          {"action": "pause", "duration": "2s"},
          {"action": "fade-in", "target": "bst", "duration": "1s", "easing": "easeOutCubic"},
          {"action": "pause", "duration": "3s"},
          {"action": "set-text", "target": "rule", "value": "Rule: Left child < Parent < Right child"},
          {"action": "fade-in", "target": "rule", "duration": "0.5s"},
          {"action": "pause", "duration": "2s"},
          {"action": "highlight-node", "target": "bst", "node": "50", "color": "$active", "duration": "0.5s"},
          {"action": "pause", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "30", "color": "$path", "duration": "0.5s"},
          {"action": "pause", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "70", "color": "$path", "duration": "0.5s"},
          {"action": "pause", "duration": "2s"},
          {"action": "set-text", "target": "rule", "value": "30 < 50 < 70  — the BST property holds!"},
          {"action": "pause", "duration": "4s"},
          {"parallel": [
            {"action": "fade-out", "target": "title", "duration": "0.5s"},
            {"action": "fade-out", "target": "subtitle", "duration": "0.5s"},
            {"action": "fade-out", "target": "bst", "duration": "0.5s"},
            {"action": "fade-out", "target": "rule", "duration": "0.5s"}
          ]}
        ]
      }
    },
    {
      "name": "insertion",
      "transition": {"type": "crossfade", "duration": "0.8s"},
      "narration": "Let's insert values into a BST step by step. We start with an empty tree and insert 50, then 30, then 70. Each value is compared with existing nodes to find the correct position. Smaller values go left, larger values go right.",
      "manifest": {
        "meta": {"title": "BST Insertion", "canvas": {"width": 1920, "height": 1080, "background": "#0f0f23"}},
        "objects": [
          {"id": "title", "type": "text", "content": "", "position": {"x": 960, "y": 60}, "style": {"font": "bold 36px sans-serif", "align": "center", "color": "#ffffff"}},
          {"id": "step", "type": "text", "content": "", "position": {"x": 960, "y": 130}, "style": {"font": "22px sans-serif", "align": "center", "color": "#b0b0dd"}},
          {"id": "bst", "type": "tree", "variant": "binary", "root": "50", "position": {"x": 960, "y": 380}, "nodes": [
            {"id": "50", "label": "50"}
          ]}
        ],
        "timeline": [
          {"action": "set-text", "target": "title", "value": "Inserting Into a BST"},
          {"parallel": [
            {"action": "fade-in", "target": "title", "duration": "0.5s"},
            {"action": "fade-in", "target": "bst", "duration": "0.5s"}
          ]},
          {"action": "set-text", "target": "step", "value": "Root node: 50"},
          {"action": "fade-in", "target": "step", "duration": "0.3s"},
          {"action": "highlight-node", "target": "bst", "node": "50", "color": "$active", "duration": "0.5s"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "Insert 30: 30 < 50 → go left"},
          {"action": "highlight-node", "target": "bst", "node": "50", "color": "$path", "duration": "0.4s"},
          {"action": "pause", "duration": "1.5s"},
          {"action": "insert-node", "target": "bst", "node": "30", "parent": "50", "side": "left", "label": "30", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "30", "color": "$inserting", "duration": "0.5s"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "Insert 70: 70 > 50 → go right"},
          {"action": "highlight-node", "target": "bst", "node": "50", "color": "$path", "duration": "0.4s"},
          {"action": "pause", "duration": "1.5s"},
          {"action": "insert-node", "target": "bst", "node": "70", "parent": "50", "side": "right", "label": "70", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "70", "color": "$inserting", "duration": "0.5s"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "Insert 20: 20 < 50 → left, 20 < 30 → left"},
          {"action": "highlight-node", "target": "bst", "node": "50", "color": "$path", "duration": "0.3s"},
          {"action": "pause", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "30", "color": "$path", "duration": "0.3s"},
          {"action": "pause", "duration": "1s"},
          {"action": "insert-node", "target": "bst", "node": "20", "parent": "30", "side": "left", "label": "20", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "20", "color": "$inserting", "duration": "0.5s"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "Insert 40: 40 < 50 → left, 40 > 30 → right"},
          {"action": "highlight-node", "target": "bst", "node": "50", "color": "$path", "duration": "0.3s"},
          {"action": "pause", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "30", "color": "$path", "duration": "0.3s"},
          {"action": "pause", "duration": "1s"},
          {"action": "insert-node", "target": "bst", "node": "40", "parent": "30", "side": "right", "label": "40", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "40", "color": "$inserting", "duration": "0.5s"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "Insert 60: 60 > 50 → right, 60 < 70 → left"},
          {"action": "highlight-node", "target": "bst", "node": "50", "color": "$path", "duration": "0.3s"},
          {"action": "pause", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "70", "color": "$path", "duration": "0.3s"},
          {"action": "pause", "duration": "1s"},
          {"action": "insert-node", "target": "bst", "node": "60", "parent": "70", "side": "left", "label": "60", "duration": "1s"},
          {"action": "highlight-node", "target": "bst", "node": "60", "color": "$inserting", "duration": "0.5s"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "Tree built! 6 nodes inserted."},
          {"action": "pause", "duration": "4s"},
          {"parallel": [
            {"action": "fade-out", "target": "title", "duration": "0.5s"},
            {"action": "fade-out", "target": "step", "duration": "0.5s"},
            {"action": "fade-out", "target": "bst", "duration": "0.5s"}
          ]}
        ]
      }
    },
    {
      "name": "search",
      "transition": {"type": "crossfade", "duration": "0.8s"},
      "narration": "Now let's search for a value. To find 40, we start at the root. 40 is less than 50, so we go left to 30. 40 is greater than 30, so we go right. And there it is! We found 40 in just 3 comparisons.",
      "manifest": {
        "meta": {"title": "BST Search", "canvas": {"width": 1920, "height": 1080, "background": "#0f0f23"}},
        "objects": [
          {"id": "title", "type": "text", "content": "", "position": {"x": 960, "y": 60}, "style": {"font": "bold 36px sans-serif", "align": "center", "color": "#ffffff"}},
          {"id": "step", "type": "text", "content": "", "position": {"x": 960, "y": 130}, "style": {"font": "22px sans-serif", "align": "center", "color": "#b0b0dd"}},
          {"id": "bst", "type": "tree", "variant": "binary", "root": "50", "position": {"x": 960, "y": 400}, "nodes": [
            {"id": "50", "label": "50"},
            {"id": "30", "label": "30", "parent": "50", "side": "left"},
            {"id": "70", "label": "70", "parent": "50", "side": "right"},
            {"id": "20", "label": "20", "parent": "30", "side": "left"},
            {"id": "40", "label": "40", "parent": "30", "side": "right"},
            {"id": "60", "label": "60", "parent": "70", "side": "left"}
          ]}
        ],
        "timeline": [
          {"action": "set-text", "target": "title", "value": "Searching in a BST"},
          {"parallel": [
            {"action": "fade-in", "target": "title", "duration": "0.5s"},
            {"action": "fade-in", "target": "bst", "duration": "0.8s"}
          ]},
          {"action": "set-text", "target": "step", "value": "Search for: 40"},
          {"action": "fade-in", "target": "step", "duration": "0.3s"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "Compare 40 with root 50: 40 < 50 → go left"},
          {"action": "highlight-node", "target": "bst", "node": "50", "color": "$path", "duration": "0.5s"},
          {"action": "highlight-edge", "target": "bst", "edge": ["50", "30"], "color": "$path", "duration": "0.5s"},
          {"action": "pause", "duration": "4s"},

          {"action": "set-text", "target": "step", "value": "Compare 40 with 30: 40 > 30 → go right"},
          {"action": "highlight-node", "target": "bst", "node": "30", "color": "$path", "duration": "0.5s"},
          {"action": "highlight-edge", "target": "bst", "edge": ["30", "40"], "color": "$path", "duration": "0.5s"},
          {"action": "pause", "duration": "4s"},

          {"action": "set-text", "target": "step", "value": "Found 40! Only 3 comparisons needed."},
          {"action": "highlight-node", "target": "bst", "node": "40", "color": "$found", "duration": "0.6s"},
          {"action": "pause", "duration": "4s"},

          {"action": "set-text", "target": "step", "value": "Now search for 65 (not in tree)"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "65 > 50 → right"},
          {"action": "highlight-node", "target": "bst", "node": "50", "color": "$visited", "duration": "0.4s"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "65 < 70 → left"},
          {"action": "highlight-node", "target": "bst", "node": "70", "color": "$visited", "duration": "0.4s"},
          {"action": "pause", "duration": "3s"},

          {"action": "set-text", "target": "step", "value": "65 > 60, but 60 has no right child → NOT FOUND"},
          {"action": "highlight-node", "target": "bst", "node": "60", "color": "$visited", "duration": "0.4s"},
          {"action": "pause", "duration": "4s"},

          {"parallel": [
            {"action": "fade-out", "target": "title", "duration": "0.5s"},
            {"action": "fade-out", "target": "step", "duration": "0.5s"},
            {"action": "fade-out", "target": "bst", "duration": "0.5s"}
          ]}
        ]
      }
    },
    {
      "name": "recap",
      "transition": {"type": "fade", "duration": "0.8s"},
      "narration": "Let's recap. BSTs keep elements sorted with the left-less-than-right rule. Searching follows a path from root to target. Insertion finds the correct leaf position. Average case is O of log n for all operations.",
      "manifest": {
        "meta": {"title": "BST Recap", "canvas": {"width": 1920, "height": 1080, "background": "#0f0f23"}},
        "objects": [
          {"id": "title", "type": "text", "content": "", "position": {"x": 960, "y": 120}, "style": {"font": "bold 36px sans-serif", "align": "center", "color": "#ffffff"}},
          {"id": "p1", "type": "text", "content": "", "position": {"x": 960, "y": 300}, "style": {"font": "24px sans-serif", "align": "center", "color": "#2ecc71"}},
          {"id": "p2", "type": "text", "content": "", "position": {"x": 960, "y": 420}, "style": {"font": "24px sans-serif", "align": "center", "color": "#f1c40f"}},
          {"id": "p3", "type": "text", "content": "", "position": {"x": 960, "y": 540}, "style": {"font": "24px sans-serif", "align": "center", "color": "#e67e22"}},
          {"id": "p4", "type": "text", "content": "", "position": {"x": 960, "y": 700}, "style": {"font": "bold 28px sans-serif", "align": "center", "color": "#00F5FF"}}
        ],
        "timeline": [
          {"action": "set-text", "target": "title", "value": "Key Takeaways"},
          {"action": "fade-in", "target": "title", "duration": "0.6s"},
          {"action": "pause", "duration": "2s"},

          {"action": "set-text", "target": "p1", "value": "1. Left < Parent < Right — the BST property"},
          {"action": "fade-in", "target": "p1", "duration": "0.5s"},
          {"action": "pause", "duration": "4s"},

          {"action": "set-text", "target": "p2", "value": "2. Search follows a root-to-leaf path"},
          {"action": "fade-in", "target": "p2", "duration": "0.5s"},
          {"action": "pause", "duration": "4s"},

          {"action": "set-text", "target": "p3", "value": "3. Insert finds the correct leaf position"},
          {"action": "fade-in", "target": "p3", "duration": "0.5s"},
          {"action": "pause", "duration": "4s"},

          {"action": "set-text", "target": "p4", "value": "Average: O(log n) — Fast!"},
          {"action": "fade-in", "target": "p4", "duration": "0.6s", "easing": "easeOutBack"},
          {"action": "pause", "duration": "4s"},

          {"parallel": [
            {"action": "fade-out", "target": "title", "duration": "0.5s"},
            {"action": "fade-out", "target": "p1", "duration": "0.5s"},
            {"action": "fade-out", "target": "p2", "duration": "0.5s"},
            {"action": "fade-out", "target": "p3", "duration": "0.5s"},
            {"action": "fade-out", "target": "p4", "duration": "0.5s"}
          ]}
        ]
      }
    }
  ]
}
